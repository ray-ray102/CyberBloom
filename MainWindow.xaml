<Window x:Class="CyberBloom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CyberBloom — Cybersecurity Awareness Chatbot"
        Height="720" Width="1000" MinHeight="620" MinWidth="860"
        Background="#F1E4E8"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,4"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2D2D34"/>
            <Setter Property="Background" Value="#CEB1BE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="7,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="5,2"/>
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="MinHeight" Value="32"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,12">
            <Image Source="logo.jpg" Height="64" Width="64" Stretch="Uniform" Margin="0,0,12,0">
                <Image.Clip>
                    <EllipseGeometry Center="32,32" RadiusX="32" RadiusY="32"/>
                </Image.Clip>
            </Image>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Cyber Bloom" FontSize="22" FontWeight="SemiBold" Foreground="#2D2D34"/>
                <TextBlock Text="Your trusted shield against cyber threats" FontSize="12"
                           Foreground="#5D5D6B" FontStyle="Italic"/>
            </StackPanel>
        </StackPanel>

        <TabControl Grid.Row="1" Background="#F1E4E8">
            <TabItem Header="Cybersecurity Chat">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#ADA0A6" BorderBrush="#2D2D34"
                            BorderThickness="1" CornerRadius="2" Margin="0,0,0,12">
                        <ScrollViewer Name="chatScroller" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled" Padding="8">
                            <ItemsControl Name="lstChat"/>
                        </ScrollViewer>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Name="txtInput" Grid.Column="0" Margin="0,4,4,4" FontSize="13"/>
                        <Button Name="btnSend" Grid.Column="1" Content="Send" Width="76" Click="BtnSend_Click"/>
                        <Button Name="btnClear" Grid.Column="2" Content="Clear" Width="76"
                                Background="#E0E0E0" Click="BtnClear_Click"/>
                    </Grid>
                </Grid>
            </TabItem>

            <TabItem Header="Task Assistant">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <GroupBox Grid.Row="0" Header="Add a task" Padding="10" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="1.6*"/>
                                <ColumnDefinition Width="0.8*"/>
                                <ColumnDefinition Width="0.8*"/>
                                <ColumnDefinition Width="1.3*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Title *" Margin="4,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Description" Margin="4,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Reminder date" Margin="4,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Hour" Margin="4,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="Minute" Margin="4,0"/>
                            <TextBlock Grid.Row="0" Grid.Column="5" Text="Reminder minutes" Margin="4,0"/>

                            <TextBox Name="txtTaskTitle" Grid.Row="1" Grid.Column="0" Margin="4" MaxLength="100"/>
                            <TextBox Name="txtTaskDescription" Grid.Row="1" Grid.Column="1" Margin="4" MaxLength="255"/>
                            <DatePicker Name="dpReminderDate" Grid.Row="1" Grid.Column="2" Margin="4"/>
                            <ComboBox Name="cmbReminderHour" Grid.Row="1" Grid.Column="3" Margin="4"/>
                            <ComboBox Name="cmbReminderMinute" Grid.Row="1" Grid.Column="4" Margin="4"/>
                            <TextBox Name="txtReminderMinutes" Grid.Row="1" Grid.Column="5" Margin="4" MaxLength="6"/>

                            <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="6"
                                        Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Add Task" Width="110" Click="AddTask_Click"/>
                                <Button Content="Refresh" Width="90" Background="#E0E0E0" Click="RefreshTasks_Click"/>
                            </StackPanel>
                        </Grid>
                    </GroupBox>

                    <DataGrid Name="dgTasks" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" CanUserAddRows="False" Margin="0,0,0,8">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding TaskID}" Width="45"/>
                            <DataGridTextColumn Header="Title" Binding="{Binding Title}" Width="1.5*"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/>
                            <DataGridTextColumn Header="Reminder" Binding="{Binding ReminderDateTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="145"/>
                            <DataGridTextColumn Header="Minutes" Binding="{Binding ReminderMinutes}" Width="75"/>
                            <DataGridCheckBoxColumn Header="Completed" Binding="{Binding IsCompleted}" Width="85"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Left">
                        <Button Content="Mark Completed" Width="140" Click="MarkCompleted_Click"/>
                        <Button Content="Delete Task" Width="140" Background="#E0E0E0" Click="DeleteTask_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Quiz">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Name="txtQuizProgress" Grid.Row="0" FontSize="14" FontWeight="SemiBold"
                               Foreground="#2D2D34" Margin="4,4,4,12"/>

                    <Border Grid.Row="1" Background="#FFFFFF" BorderBrush="#ADA0A6"
                            BorderThickness="1" CornerRadius="2" Padding="18">
                        <StackPanel>
                            <TextBlock Name="txtQuizQuestion" FontSize="17" FontWeight="SemiBold"
                                       Foreground="#2D2D34" TextWrapping="Wrap" Margin="0,0,0,14"/>
                            <RadioButton Name="rbQuizOption1" GroupName="QuizAnswers" Margin="4,7"/>
                            <RadioButton Name="rbQuizOption2" GroupName="QuizAnswers" Margin="4,7"/>
                            <RadioButton Name="rbQuizOption3" GroupName="QuizAnswers" Margin="4,7"/>
                            <RadioButton Name="rbQuizOption4" GroupName="QuizAnswers" Margin="4,7"/>
                            <TextBlock Name="txtQuizFeedback" Margin="4,16,4,0" FontWeight="SemiBold"
                                       Foreground="#5D5D6B" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>

                    <Button Grid.Row="2" Content="Submit Answer" Width="130" HorizontalAlignment="Right"
                            Margin="4,12,4,4" Click="SubmitQuizAnswer_Click"/>
                </Grid>
            </TabItem>

            <TabItem Header="Activity Log">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="CyberBloom activity" FontSize="17" FontWeight="SemiBold"
                               Foreground="#2D2D34" Margin="4,4,4,10"/>
                    <ListBox Name="lstActivityLog" Grid.Row="1" Background="#FFFFFF"
                             BorderBrush="#ADA0A6" BorderThickness="1" Padding="6"/>
                    <Button Grid.Row="2" Content="Clear Activity Log" Width="150" HorizontalAlignment="Right"
                            Background="#E0E0E0" Click="ClearActivityLog_Click"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
