<Window x:Class="CyberBloom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberBloom"
        mc:Ignorable="d"
        Title="CyberBloom — Cybersecurity Awareness Chatbot"
        Height="650" Width="480"
        Background="#F1E4E8"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,16">
            <Image Name="imgLogo" Source="logo.jpg" Height="80" Width="80"
                   Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,10">
                <Image.Clip>
                    <EllipseGeometry Center="40,40" RadiusX="40" RadiusY="40"/>
                </Image.Clip>
            </Image>
            <TextBlock Text="Cyber Bloom"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="#2D2D34"
                       TextAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Text="Your trusted shield against cyber threats"
                       FontSize="12" Foreground="#5D5D6B"
                       TextAlignment="Center" FontStyle="Italic"/>
        </StackPanel>

        <!-- Chat Display -->
        <Border Grid.Row="1"
                Background="#ADA0A6"
                BorderBrush="#2D2D34"
                BorderThickness="1"
                CornerRadius="2"
                Margin="0,0,0,12">
            <ScrollViewer Name="chatScroller"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="8">
                <ItemsControl Name="lstChat"/>
            </ScrollViewer>
        </Border>

        <!-- Input Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    BorderBrush="#2D2D34"
                    BorderThickness="1"
                    CornerRadius="2"
                    Margin="0,0,8,0"
                    Background="#FFFFFF">
                <TextBox Name="txtInput"
                         BorderThickness="0"
                         Background="Transparent"
                         Height="36"
                         Padding="10,0"
                         VerticalContentAlignment="Center"
                         FontSize="13"
                         Foreground="#2D2D34"/>
            </Border>

            <Button Name="btnSend" Grid.Column="1"
                    Content="Send"
                    Width="72" Height="36"
                    Margin="0,0,8,0"
                    Click="BtnSend_Click"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="#2D2D34"
                    Background="#CEB1BE"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#BFA0AE"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#AF909E"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

            <Button Name="btnClear" Grid.Column="2"
                    Content="Clear"
                    Width="72" Height="36"
                    Click="BtnClear_Click"
                    FontSize="13"
                    Foreground="#2D2D34"
                    Background="#E0E0E0"
                    BorderThickness="0"
                    Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="2">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#CFCFCF"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter Property="Background" Value="#BEBEBE"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>
    </Grid>
</Window>